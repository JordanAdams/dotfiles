" Set indentation to 2 spaces
set tabstop=2
set shiftwidth=2
set expandtab
set smartindent

" Disable word-wrap
set nowrap

" Enable relative and current line numbers
set number
set relativenumber

" Use the system clipboard
set clipboard=unnamed

" Enable mouse input
set mouse=a

" Enable true colours
set termguicolors

" Set the colour scheme
colorscheme base16-gruvbox-dark-hard
let base16colorspace=256
